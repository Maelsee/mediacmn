# 应用环境变量示例
# 可通过 ENV_FILE 指定 .env 绝对路径，默认加载项目根目录下 .env
# 例如：ENV_FILE=/home/meal/Django-Web/mediacmn/media-server/.env
APP_NAME=MediaCMN Server
ENVIRONMENT=development

# CORS 允许来源
# 支持逗号分隔：
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# 或 JSON 列表（需要确保是合法的 URL）：
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ORIGINS=*
# sqlist数据库配置
SQLITE_DATABASE_URL=sqlite:///./mediacmn.db
# PostgreSQL 连接字符串
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mediacmn
# Redis 配置
REDIS_URL=redis://:redis123@localhost:9001
REDIS_DB=0
# 环境变量，用于区分开发环境和生产环境
ENVIRONMENT=production
# JWT 配置
JWT_SECRET_KEY=please_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=3600
MASTER_KEY=master_key
# TMDB API Key（用于元数据刮削）
TMDB_API_KEY=b4f22c4e74c07e203bb45ce126ab2193
TMDB_V4_TOKEN=eyJhbGciOiJIUzI1NiJ9.eyJhdWQiOiJiNGYyMmM0ZTc0YzA3ZTIwM2JiNDVjZTEyNmFiMjE5MyIsIm5iZiI6MTc2MTg5ODA0OS43NjEsInN1YiI6IjY5MDQ2ZTQxOWFiYTE5OTg4ODE3ZjZkZiIsInNjb3BlcyI6WyJhcGlfcmVhZCJdLCJ2ZXJzaW9uIjoxfQ.GIOqWyUZiPovqM8kttfcH01i3gX1yfFAGCdYc_VaPVE
# 扫描策略（默认 Depth=1，递归与增量由应用配置启用）
SCAN_DEFAULT_DEPTH=1

# 启用的刮削器插件（逗号分隔）
ENABLE_SCRAPERS=["tmdb"]

# WebDAV 多存储配置（JSON 文本）
# 示例：
# WEBDAV_STORAGES=[{"name":"maelsea","hostname":"http://maelsea.site:5244","login":"mael","password":"110","root":"/dav/302/133quark302/test"}]