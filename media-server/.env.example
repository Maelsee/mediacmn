# 应用环境变量示例
# 可通过 ENV_FILE 指定 .env 绝对路径，默认加载项目根目录下 .env
# 例如：ENV_FILE=/home/meal/Django-Web/mediacmn/media-server/.env
APP_NAME=MediaCMN Server
ENVIRONMENT=development

# CORS 允许来源
# 支持逗号分隔：
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# 或 JSON 列表（需要确保是合法的 URL）：
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ORIGINS=http://localhost:3000

# PostgreSQL 连接字符串
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mediacmn

# JWT 配置
JWT_SECRET_KEY=please_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 元数据服务 API Key（全局 .env 管理）
# TMDB_API_KEY=your_tmdb_api_key
# TMDB_V4_TOKEN=your_tmdb_v4_bearer_token
# TVMAZE_API_KEY=your_tvmaze_api_key

# 扫描策略（默认 Depth=1，启用递归与增量）
# SCAN_DEFAULT_DEPTH=1
# SCAN_ENABLE_RECURSIVE=true
# SCAN_ENABLE_INCREMENTAL=true
# SEARCH_SIMPLE_ENABLED=true

# WebDAV 多存储配置（JSON 文本）
# 示例：
# WEBDAV_STORAGES=[{"name":"maelsea","hostname":"http://maelsea.site:5244","login":"mael","password":"110","root":"/dav/302/133quark302/test"}]