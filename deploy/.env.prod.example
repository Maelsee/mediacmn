DOMAIN=maelsea.site

POSTGRES_DB=mediacmn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_PASSWORD=redis123
REDIS_CACHE_PASSWORD=redis123

APP_NAME=MediaCMN Server
ENVIRONMENT=production
CORS_ORIGINS=["http://maelsea.site:6069"]

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/mediacmn

REDIS_URL=redis://:redis123@redis_queue:6379
REDIS_DB=0

SCRAPER_CACHE_REDIS_URL=redis://:redis123@redis_cache:6379
SCRAPER_CACHE_REDIS_DB=0

JWT_SECRET_KEY=please_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=3600
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_ROTATION=true
MASTER_KEY=please_change_me

PLAYURL_MODE=direct_signed
URL_SIGNING_SECRET=please_change_me
URL_SIGNING_TTL_SECONDS=300
URL_SIGNING_ALG=HS256

TMDB_API_KEY=
TMDB_V4_TOKEN=
TMDB_LANGUAGE=zh-CN
TMDB_FALLBACK_LANGUAGE=en-US
TMDB_TIMEOUT=30
TMDB_PROXY=

SCAN_DEFAULT_DEPTH=1
ENABLE_SCRAPERS=["tmdb"]
