DOMAIN=127.22.0.7

POSTGRES_DB=mediacmn
POSTGRES_USER=postgrespass
POSTGRES_PASSWORD=postgrespass

REDIS_PASSWORD=redispass
REDIS_CACHE_PASSWORD=redispass

APP_NAME=MediaCMN Server
ENVIRONMENT=production
CORS_ORIGINS=["http://127.22.0.7:80"]
DATABASE_URL=postgresql+psycopg://postgrespass:postgrespass@postgres:5432/mediacmn


REDIS_URL=redis://:redispass@redis_queue:6379
REDIS_DB=0

SCRAPER_CACHE_REDIS_URL=redis://:redispass@redis_queue:6379
SCRAPER_CACHE_REDIS_DB=2

JWT_SECRET_KEY=please_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=3600
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_ROTATION=true
MASTER_KEY=please_change_me

PLAYURL_MODE=direct_signed
URL_SIGNING_SECRET=please_change_me
URL_SIGNING_TTL_SECONDS=300
URL_SIGNING_ALG=HS256

TMDB_API_KEY=
TMDB_V4_TOKEN=
TMDB_LANGUAGE=zh-CN
TMDB_FALLBACK_LANGUAGE=en-US
TMDB_TIMEOUT=30
# 如果使用 Vercel 代理，请设置以下两个地址
TMDB_API_BASE_URL=
TMDB_IMAGE_BASE_URL=

SCAN_DEFAULT_DEPTH=1
ENABLE_SCRAPERS=["tmdb"]
